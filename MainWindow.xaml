<Window x:Class="FacadeModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Facade Mod Manager" Height="500" Width="900"
        Background="#121212" Foreground="White" FontFamily="Segoe UI Semibold">

    <Grid Loaded="OnLoad">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="0,15,15,0">
            <Grid Margin="20">
                <Grid.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Margin" Value="0,5"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Resources>

                <StackPanel>
                    <Border CornerRadius="10" ClipToBounds="True" Height="100" Margin="0,0,0,10">
                        <Image Source="/Image1.png" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Text="FACADE" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="modManagerLabel" Text="Mod Manager v1.0" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                    <Button x:Name="modsButton" Content="Mods" Click="modsButton_Click" />
                    <Button x:Name="facadeSettingsButton" Content="Facade Settings" Click="facadeSettingsButton_Click" />
                    <Button x:Name="modLoaderSettingsButton" Content="ModLoader Settings" Click="modLoaderSettingsButton_Click" />
                </StackPanel>

                <Button x:Name="installButton" Content="INSTALL" VerticalAlignment="Bottom" Height="45" 
                        Background="#3D5AFE" FontWeight="Bold" Cursor="Hand" Click="installButton_Click"/>
            </Grid>
        </Border>
        <Grid Grid.Column="1" Margin="40">
            <Grid VerticalAlignment="Stretch">
                <StackPanel x:Name="WelcomeScreen" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Welcome back!" 
                       FontSize="42" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

                    <TextBlock Text="Get started by clicking one of the buttons on the left." 
                       FontSize="18" 
                       TextWrapping="Wrap" 
                       TextAlignment="Center"
                       Opacity="0.5" 
                       MaxWidth="400" Width="398"/>
                </StackPanel>

                <Grid x:Name="FacadeSettingsContainer" Visibility="Collapsed">
                    <Grid.Resources>
                        <Style x:Key="BetterCheck" TargetType="CheckBox">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <Grid Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="Box" Width="22" Height="22" 
                                        CornerRadius="6" BorderThickness="2" 
                                        BorderBrush="#3D5AFE" Background="Transparent">
                                                    <Path x:Name="CheckMark" Data="M 4,8 L 8,12 L 14,4" 
                                          Stroke="White" StrokeThickness="2" 
                                          Visibility="Collapsed"/>
                                                </Border>
                                                <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Box" Property="Background" Value="#3D5AFE"/>
                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Box" Property="BorderBrush" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>

                    <StackPanel>
                        <TextBlock Text="Facade Settings" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

                        <Border Background="#1E1E1E" CornerRadius="15" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Skip Intro Scene" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Skips the opening credits, saving you approximately 30 seconds or so." 
                               Foreground="Gray" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>

                                <CheckBox Grid.Column="1" x:Name="IntroSkipCheck" 
                          Style="{StaticResource BetterCheck}"
                          Cursor="Hand" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ModLoaderSettingsContainer" Visibility="Collapsed">
                    <Grid.Resources>
                        <Style x:Key="BetterCheck" TargetType="CheckBox">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <Grid Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="Box" Width="22" Height="22" 
                        CornerRadius="6" BorderThickness="2" 
                        BorderBrush="#3D5AFE" Background="Transparent">
                                                    <Path x:Name="CheckMark" Data="M 4,8 L 8,12 L 14,4" 
                          Stroke="White" StrokeThickness="2" 
                          Visibility="Collapsed"/>
                                                </Border>
                                                <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Box" Property="Background" Value="#3D5AFE"/>
                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Box" Property="BorderBrush" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>

                    <StackPanel>
                        <TextBlock Text="ModLoader Settings" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

                        <Border Background="#1E1E1E" CornerRadius="15" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Show Console" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Shows a separate console when launching Facade. Mods may use this for debugging." 
               Foreground="Gray" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>

                                <CheckBox Grid.Column="1" x:Name="ShowConsole" 
          Style="{StaticResource BetterCheck}"
          Cursor="Hand" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ModListContainer" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Available Mods" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

                    <ListBox Grid.Row="1" x:Name="ModsListBox" 
         Background="Transparent" BorderThickness="0" 
         ScrollViewer.VerticalScrollBarVisibility="Auto"
         HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="Padding" Value="20"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A2A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="20,5" Height="65">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="{Binding Description}" FontSize="13" Foreground="Gray" TextWrapping="Wrap" MaxWidth="400"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding Version}" Foreground="LightGray"
                           VerticalAlignment="Center" HorizontalAlignment="Right" 
                           FontSize="12" Opacity="0.6" Margin="0,0,20,0"/>

                                    <Button Grid.Column="2" 
                                        Width="120" Height="35"
                                        Click="ModAction_Click"
                                        Cursor="Hand">      
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Installed}" Value="True">
                                                        <Setter Property="Content" Value="UNINSTALL"/>
                                                        <Setter Property="Background" Value="Crimson"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Installed}" Value="False">
                                                        <Setter Property="Content" Value="INSTALL"/>
                                                        <Setter Property="Background" Value="Green"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>

            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                <Rectangle Height="1" Width="100" Fill="White" Opacity="0.1" Margin="0,0,0,15"/>
                <TextBlock Text="CREDITS" 
                   FontSize="10" 
                   FontWeight="Black" 
                   Opacity="0.3" 
                   HorizontalAlignment="Center"/>
                <TextBlock Text="G4B33 - Intro skip seen under 'Facade Settings'" 
                   FontSize="12" 
                   Opacity="0.5" 
                   HorizontalAlignment="Center" 
                   Margin="0,5,0,0"/>
                <TextBlock Text="noia.site - Mod manager, mod loader, some of the mods listed" 
                   FontSize="12" 
                   Opacity="0.5" 
                   HorizontalAlignment="Center" 
                   Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>